{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "requireBranch": "main",
    "tagName": "v${version}"
  },
  "github": {
    "autoGenerate": true,
    "release": true
  },
  "npm": false,
  "plugins": {
    "@release-it/bumper": {
      "in": "package.json",
      "out": "package.json"
    }
  },
  "hooks": {
    "before:init": ["bun test", "bun typecheck"],
    "after:git:release": "npm publish"
  }
}
