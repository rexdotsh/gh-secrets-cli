{
  "name": "gh-secrets",
  "version": "0.0.0",
  "description": "CLI for managing GitHub Actions secrets",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "keywords": [
    "github-actions",
    "gh-secrets",
    "github-actions-secrets",
    "github-secrets",
    "actions-secrets",
    "secrets",
    "cli",
    "bun"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.9"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "gh-secrets": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run --hot --no-clear-screen src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outfile=dist/index.js --packages=external",
    "prepack": "bun run build",
    "start": "bun run src/cli.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "bun x ultracite check",
    "fix": "bun x ultracite fix",
    "format": "biome format --write",
    "test": "bun test"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "dotenv": "^17.2.3",
    "libsodium-wrappers": "^0.8.2",
    "picomatch": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "^1.3.9",
    "@types/picomatch": "^4.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260223.1",
    "lefthook": "^2.1.1",
    "ultracite": "7.2.3"
  }
}
